    "### FASE 2: Validación RFNBO en SAP BTP\n",
    "\n",
    "Orquestación en SAP Integration Suite con validación de directivas EU RED II/III."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@decorador_event_mesh\n",
    "def procesar_iFlow_BTP_RFNBO(payload_edge: Dict) -> Tuple[Dict, Dict]:\n",
    "    \"\"\"Validación RFNBO en SAP BTP Integration Suite.\n",
    "    \n",
    "    Implementa:\n",
    "    - Correlación temporal RFNBO (energía renovable ≥ consumo)\n",
    "    - Validaciones ISO 14687 y SAE J2601\n",
    "    - Mapeo a OData API_BATCH_SRV para SAP MM\n",
    "    \"\"\"\n",
    "    try:\n",
    "        metadata = payload_edge[\"gateway_metadata\"]\n",
    "        activos = payload_edge[\"identificadores_activos\"]\n",
    "        metricas = payload_edge[\"metricas_industriales\"]\n",
    "        \n",
    "        timestamp_str = metadata[\"timestamp_utc\"].rstrip('Z')\n",
    "        ts_evento = datetime.datetime.fromisoformat(timestamp_str)\n",
    "        \n",
    "        # Validaciones\n",
    "        correlacion_geografica = (activos[\"nodo_electrico\"] == \"ES_NODO_SUR\")\n",
    "        deficit_energetico = metricas[\"mwh_generados_renovable_ppa\"] - metricas[\"mwh_consumidos_electrolizador\"]\n",
    "        correlacion_temporal = deficit_energetico >= 0\n",
    "        pureza_conforme = (metricas[\"pureza_porcentaje_iso14687\"] >= 99.9)\n",
    "        humedad_conforme = (metricas.get(\"humedad_ppm\", 0) <= 5.0)\n",
    "        termico_sae_conforme = (metricas[\"temperatura_sae_j2601_c\"] <= -35.0)\n",
    "        \n",
    "        es_verde_legal = all([correlacion_geografica, correlacion_temporal, pureza_conforme, humedad_conforme, termico_sae_conforme])\n",
    "        \n",
    "        payload_odata_sap = {\n",
    "            \"Material\": \"H2_GREEN_PREMIUM\" if es_verde_legal else \"H2_NON_COMPLIANT\",\n",
    "            \"BatchStatus\": EstadoLoteSAP.CONFORME.value if es_verde_legal else EstadoLoteSAP.RESTRINGIDO.value,\n",
    "            \"Characteristics\": [\n",
    "                {\"CharName\": \"Z_ORIGIN_TYPE\", \"CharValue\": \"RFNBO_COMPLIANT\" if es_verde_legal else \"GREY_GRID_NON_COMPLIANT\"},\n",
    "                {\"CharName\": \"Z_CO2_FOOTPRINT\", \"CharValue\": f\"{0.38 if es_verde_legal else 13.80} gCO2eq/MJ\"},\n",
    "                {\"CharName\": \"Z_CERTIFICATE_NUM\", \"CharValue\": f\"EU-RFNBO-{ts_evento.strftime('%Y%m%d%H%M')}-ELEC01\" if es_verde_legal else \"NOT_AVAILABLE\"},\n",
    "                {\"CharName\": \"Z_PRESSURE_MAX_PS\", \"CharValue\": str(metricas[\"presion_bar\"])},\n",
    "                {\"CharName\": \"Z_HEF_METRIC\", \"CharValue\": str(int(metricas[\"hef_desgaste_acumulado\"]))},\n",
    "                {\"CharName\": \"Z_PURITY_ISO14687\", \"CharValue\": f\"{metricas['pureza_porcentaje_iso14687']:.2f}%\"},\n",
    "                {\"CharName\": \"Z_HUMIDITY_ISO14687\", \"CharValue\": f\"{metricas.get('humedad_ppm', 0):.1f} ppm\"},\n",
    "                {\"CharName\": \"Z_TEMPERATURE_SAE\", \"CharValue\": f\"{metricas['temperatura_sae_j2601_c']:.1f}°C\"},\n",
    "                {\"CharName\": \"Z_ENERGY_BALANCE\", \"CharValue\": f\"{deficit_energetico:.3f} MWh\"}\n",
    "            ],\n",
    "            \"BTP_Routing_Metadata\": {\n",
    "                \"Target_Plant\": \"HU01\",\n",
    "                \"Compliance_Status\": \"PASSED\" if es_verde_legal else \"FAILED\",\n",
    "                \"Timestamp_Decision\": ts_evento.isoformat()\n",
    "            }\n",
    "        }\n",
    "        \n",
    "        validation_report = {\n",
    "            \"timestamp\": ts_evento.isoformat(),\n",
    "            \"validaciones\": {\n",
    "                \"correlacion_geografica\": \"PASSED\" if correlacion_geografica else \"FAILED\",\n",
    "                \"correlacion_temporal_rfnbo\": \"PASSED\" if correlacion_temporal else \"FAILED\",\n",
    "                \"pureza_iso14687\": \"PASSED\" if pureza_conforme else \"FAILED\",\n",
    "                \"humedad_iso14687\": \"PASSED\" if humedad_conforme else \"FAILED\",\n",
    "                \"temperatura_sae_j2601\": \"PASSED\" if termico_sae_conforme else \"FAILED\"\n",
    "            },\n",
    "            \"estado_final\": \"CONFORME\" if es_verde_legal else \"NO_CONFORME\"\n",
    "        }\n",
    "        \n",
    "        logger.info(f\"✓ Validación RFNBO completada - Estado: {validation_report['estado_final']}\")\n",
    "        return payload_odata_sap, validation_report\n",
    "        \n",
    "    except Exception as e:\n",
    "        logger.error(f\"❌ Error en procesamiento RFNBO: {str(e)}\")\n",
    "        raise\n",
    "\n",
    "print(\"✓ Servidor de reglas Fase 2 cargado (SAP BTP Integration Suite).\")"
   ]
  },
