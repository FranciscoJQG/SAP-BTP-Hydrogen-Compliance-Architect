   "source": [
    "### FASE 8: Auditoría y Reporting Final\n",
    "\n",
    "Generación de reporte completo de transacciones y cumplimiento."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def generar_reporte_transaccional_completo(pipeline_obj: HydrogenCompliancePipeline) -> Dict:\n",
    "    \"\"\"Genera reporte completo de transacciones SAP y cumplimiento.\n",
    "    \n",
    "    Returns:\n",
    "        Dict con estadísticas de transacciones, lotes, despachos y facturación\n",
    "    \"\"\"\n",
    "    try:\n",
    "        # Estadísticas de transacciones\n",
    "        total_migo = len(pipeline_obj.tabla_MIGO_movimientos)\n",
    "        total_lotes_mm = len(pipeline_obj.tabla_MCHA_cabecera_lotes)\n",
    "        total_expediciones = len(pipeline_obj.tabla_LIPS_expediciones)\n",
    "        total_eventos_mesh = len(pipeline_obj.event_mesh_queue)\n",
    "        \n",
    "        # Contadores de conformidad\n",
    "        lotes_conformes = sum(\n",
    "            1 for lote in pipeline_obj.tabla_MCHA_cabecera_lotes.values()\n",
    "            if lote.get(\"COMPLIANCE_FLAG\") == \"GREEN\"\n",
    "        )\n",
    "        \n",
    "        despachos_aprobados = sum(\n",
    "            1 for evt in pipeline_obj.tabla_audit_trail\n",
    "            if \"APROBADO\" in evt.get(\"evento\", \"\")\n",
    "        )\n",
    "        \n",
    "        despachos_bloqueados = sum(\n",
    "            1 for evt in pipeline_obj.tabla_audit_trail\n",
    "            if \"BLOQUEADO\" in evt.get(\"evento\", \"\")\n",
    "        )\n",
    "        \n",
    "        reporte = {\n",
    "            \"timestamp_reporte\": datetime.datetime.now(datetime.timezone.utc).isoformat(),\n",
    "            \"transacciones_sap\": {\n",
    "                \"MIGO_movimientos\": total_migo,\n",
    "                \"MCHA_lotes_registrados\": total_lotes_mm,\n",
    "                \"AUSP_caracteristicas_registradas\": sum(len(chars) for chars in pipeline_obj.tabla_AUSP_caracteristicas.values()),\n",
    "                \"VL01N_expediciones\": total_expediciones,\n",
    "                \"VF01_facturas_emitidas\": sum(1 for evt in pipeline_obj.tabla_audit_trail if \"VF01\" in evt.get(\"evento\", \"\"))\n",
    "            },\n",
    "            \"integracion_btp\": {\n",
    "                \"event_mesh_eventos_encolados\": total_eventos_mesh,\n",
    "                \"cloud_connector_tokens_activos\": len(pipeline_obj.cloud_connector_tokens)\n",
    "            },\n",
    "            \"conformidad_rfnbo\": {\n",
    "                \"lotes_conformes\": lotes_conformes,\n",
    "                \"lotes_no_conformes\": total_lotes_mm - lotes_conformes,\n",
    "                \"tasa_cumplimiento_pct\": round((lotes_conformes / total_lotes_mm * 100) if total_lotes_mm > 0 else 0, 2)\n",
    "            },\n",
    "            \"despachos_sd\": {\n",
    "                \"despachos_aprobados\": despachos_aprobados,\n",
    "                \"despachos_bloqueados\": despachos_bloqueados,\n",
    "                \"tasa_bloqueo_pct\": round((despachos_bloqueados / (despachos_aprobados + despachos_bloqueados) * 100) if (despachos_aprobados + despachos_bloqueados) > 0 else 0, 2)\n",
    "            },\n",
    "            \"blockchain_auditoria\": {\n",
    "                \"certificados_digitales\": len(pipeline_obj.tabla_certificados_digitales),\n",
    "                \"eventos_auditoria_trail\": len(pipeline_obj.tabla_audit_trail)\n",
    "            }\n",
    "        }\n",
    "        \n",
    "        logger.info(f\"✓ Reporte transaccional generado - MIGO: {total_migo} | MM: {total_lotes_mm} | SD: {total_expediciones}\")\n",
    "        return reporte\n",
